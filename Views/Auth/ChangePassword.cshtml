@model SmartELibrary.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="change-password-page">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-xl-5">
            <div class="card auth-card change-password-card">
                <div class="card-body p-4 p-md-5">
                    <h4 class="mb-1 text-white">Change Password</h4>
                    <p class="mb-4 change-password-subtitle">Update your account password safely.</p>
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label text-light"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label text-light"></label>
                            <input asp-for="CurrentPassword" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label text-light"></label>
                            <input asp-for="NewPassword" class="form-control" />
                        </div>
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label text-light"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                        </div>
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary change-password-submit">Change Password</button>
                        </div>
                        <div class="mt-3 text-end">
                            <a href="javascript:history.back()" class="change-password-back-link">Cancel and go back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
